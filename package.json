{
  "name": "cypress-saucedemo-framework",
  "version": "1.0.0",
  "description": "This project is a test automation framework built with Cypress for the SauceDemo web application. It demonstrates an automation-first, SDET-oriented approach focusing on reliable, maintainable, and scalable testing.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "cy:smoke": "cypress run --spec 'cypress/e2e/smoke/**/*.cy.ts'",
    "cy:e2e": "cypress run --spec 'cypress/e2e/feature/**/*.cy.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ida-jankowska/cypress-saucedemo-framework.git"
  },
